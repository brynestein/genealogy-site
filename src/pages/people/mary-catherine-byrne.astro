---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const person = {
  name: 'Mary Catherine Byrne',
  born: 'September 8, 1887',
  bornPlace: 'Castlebar, County Mayo',
  died: 'January 23, 1962',
  diedPlace: 'Liverpool, Merseyside',
  age: 74,
  quote: 'The memories we make with our family is everything.',
  bio: [
    "Mary Catherine Byrne was born in Castlebar, County Mayo, the eldest daughter of Thomas J. Byrne and Bridget McHale. She left Ireland in the autumn of 1909, travelling alone to Liverpool to join her uncle's household in Bootle.",
    "She married Patrick Whelan in 1912 at St. Alexander's, Bootle. The couple raised six children, four of whom appear elsewhere in this archive. Mary kept letters, photographs and parish documents from both sides of the Irish Sea, and a substantial portion of this site is built directly from materials she preserved.",
  ],
  facts: [
    { label: 'Born',       value: 'September 8, 1887', sub: 'Castlebar, Co. Mayo' },
    { label: 'Died',       value: 'January 23, 1962', sub: 'Liverpool, age 74' },
    { label: 'Father',     value: 'Thomas J. Byrne', sub: '1854 – 1921' },
    { label: 'Mother',     value: 'Bridget McHale',  sub: '1859 – 1934' },
    { label: 'Spouse',     value: 'Patrick Whelan',  sub: 'm. 1912, Bootle' },
    { label: 'Children',   value: '6 documented',    sub: '4 with profiles' },
  ],
  records: [
    { kind: 'Birth cert.',  year: '1887', source: 'GRO Ireland · Castlebar district' },
    { kind: 'Passenger list', year: '1909', source: 'SS Anglia · Dublin → Liverpool' },
    { kind: 'Marriage record', year: '1912', source: "St. Alexander's RC, Bootle" },
    { kind: 'Census return', year: '1921', source: 'England & Wales · Bootle' },
    { kind: 'Death cert.',  year: '1962', source: 'GRO England · Liverpool South' },
  ],
};

// Tree data — Mary at the root, parents above, siblings + spouse + children below
const tree = {
  ancestors: [
    { name: 'Thomas J. Byrne', dates: '1854 – 1921', tint: 'sepia' },
    { name: 'Bridget McHale',  dates: '1859 – 1934', tint: 'rose' },
  ],
  self: { name: 'Mary Catherine Byrne', dates: '1887 – 1962', tint: 'sage', self: true },
  spouse: { name: 'Patrick Whelan', dates: '1884 – 1951', tint: 'sepia' },
  siblings: [
    { name: 'John Byrne',    dates: '1889 – 1948', tint: 'sepia' },
    { name: 'Annie Byrne',   dates: '1892 – 1971', tint: 'rose' },
    { name: 'Michael Byrne', dates: '1896 – 1917', tint: 'sepia' },
  ],
  children: [
    { name: 'Eliza Whelan',   dates: '1913 – 1989', tint: 'rose' },
    { name: 'Thomas Whelan',  dates: '1915 – 1982', tint: 'sepia' },
    { name: 'Bridget Whelan', dates: '1918 – 2001', tint: 'rose' },
    { name: 'James Whelan',   dates: '1921 – 1944', tint: 'sepia' },
  ],
};
---

<Layout title={`${person.name} — Genealogy Site`} description={`Profile and family tree for ${person.name}, ${person.born.split(',')[1].trim()}–${person.died.split(',')[1].trim()}.`}>
  <Header />

  <main>
    <!-- PROFILE HERO -->
    <section class="profile-hero">
      <div class="container profile-inner">
        <div class="profile-avatar">
          <div class="avatar-ring">
            <div class="avatar-disc"></div>
          </div>
          <span class="profile-line">b. {person.born.split(',')[0]}</span>
          <span class="profile-line">d. {person.died.split(',')[0]}</span>
        </div>
        <div class="profile-text">
          <p class="eyebrow">Member profile</p>
          <h1>{person.name}</h1>
          <p class="lifespan">{person.born.split(',').pop()?.trim()}&nbsp;–&nbsp;{person.died.split(',').pop()?.trim()} · aged {person.age}</p>
          <blockquote class="profile-quote">
            <span class="mark">&ldquo;</span>{person.quote}
          </blockquote>
          <div class="profile-cta">
            <a href="#tree" class="btn btn-primary">View family tree</a>
            <a href="#bio" class="btn btn-ghost">Read biography</a>
          </div>
        </div>
      </div>
    </section>

    <!-- QUICK FACTS -->
    <section class="section facts-section">
      <div class="container">
        <div class="facts-grid">
          {person.facts.map(f => (
            <div class="fact">
              <p class="fact-label">{f.label}</p>
              <p class="fact-value">{f.value}</p>
              <p class="fact-sub">{f.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BIOGRAPHY -->
    <section id="bio" class="section section-alt">
      <div class="container narrow">
        <p class="eyebrow centered">Biography</p>
        <h2 class="centered">A life across two countries</h2>
        {person.bio.map(p => <p class="bio-para">{p}</p>)}
      </div>
    </section>

    <!-- FAMILY TREE -->
    <section id="tree" class="section section-tree">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Family tree</p>
          <h2>{person.name.split(' ')[0]}'s family</h2>
        </div>

        <div class="tree-frame">
          <div class="tree-controls" aria-hidden="true">
            <button class="tree-btn" title="Zoom in">+</button>
            <button class="tree-btn" title="Zoom out">−</button>
            <button class="tree-btn" title="Reset">⟳</button>
          </div>

          <div class="tree-canvas">
            <!-- Row 1: parents -->
            <div class="tree-row tree-row-parents">
              {tree.ancestors.map(p => (
                <div class={`tree-node tint-${p.tint}`}>
                  <div class="node-avatar"></div>
                  <p class="node-name">{p.name}</p>
                  <p class="node-dates">{p.dates}</p>
                </div>
              ))}
            </div>

            <!-- Connector: parents → self -->
            <svg class="tree-connector connector-parents" viewBox="0 0 800 80" preserveAspectRatio="none" aria-hidden="true">
              <path d="M 200 0 L 200 30 L 400 30 L 400 80 M 600 0 L 600 30 L 400 30" stroke="#b5a892" stroke-width="2" fill="none"/>
            </svg>

            <!-- Row 2: self + spouse, with siblings flanking -->
            <div class="tree-row tree-row-self">
              <div class="sibling-cluster">
                {tree.siblings.slice(0, 2).map(s => (
                  <div class={`tree-node tree-node-sm tint-${s.tint}`}>
                    <div class="node-avatar"></div>
                    <p class="node-name">{s.name}</p>
                    <p class="node-dates">{s.dates}</p>
                  </div>
                ))}
              </div>

              <div class="couple">
                <div class={`tree-node tree-node-lg tint-${tree.self.tint} is-self`}>
                  <div class="node-avatar"></div>
                  <p class="node-name">{tree.self.name}</p>
                  <p class="node-dates">{tree.self.dates}</p>
                  <span class="node-tag">This profile</span>
                </div>
                <div class="couple-link" aria-hidden="true">
                  <span class="couple-line"></span>
                  <span class="couple-mark">∞</span>
                </div>
                <div class={`tree-node tree-node-lg tint-${tree.spouse.tint}`}>
                  <div class="node-avatar"></div>
                  <p class="node-name">{tree.spouse.name}</p>
                  <p class="node-dates">{tree.spouse.dates}</p>
                  <span class="node-tag">Spouse</span>
                </div>
              </div>

              <div class="sibling-cluster">
                {tree.siblings.slice(2).map(s => (
                  <div class={`tree-node tree-node-sm tint-${s.tint}`}>
                    <div class="node-avatar"></div>
                    <p class="node-name">{s.name}</p>
                    <p class="node-dates">{s.dates}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Connector: couple → children -->
            <svg class="tree-connector connector-children" viewBox="0 0 800 80" preserveAspectRatio="none" aria-hidden="true">
              <path d="M 400 0 L 400 30 L 120 30 L 120 80 M 400 30 L 320 30 L 320 80 M 400 30 L 520 30 L 520 80 M 400 30 L 720 30 L 720 80" stroke="#b5a892" stroke-width="2" fill="none"/>
            </svg>

            <!-- Row 3: children -->
            <div class="tree-row tree-row-children">
              {tree.children.map(c => (
                <div class={`tree-node tree-node-sm tint-${c.tint}`}>
                  <div class="node-avatar"></div>
                  <p class="node-name">{c.name}</p>
                  <p class="node-dates">{c.dates}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- RECORDS / SOURCES -->
    <section class="section">
      <div class="container narrow">
        <p class="eyebrow">Source records</p>
        <h2>Documents on file</h2>
        <ul class="records">
          {person.records.map(r => (
            <li class="record">
              <div class="record-icon">📄</div>
              <div class="record-body">
                <p class="record-kind">{r.kind} <span class="record-year">· {r.year}</span></p>
                <p class="record-source">{r.source}</p>
              </div>
              <a href="#" class="record-link">View &rarr;</a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  :global(:root) { --home-width: 1180px; }
  .container { max-width: var(--home-width); }
  .container.narrow { max-width: 760px; }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    color: #8a7a5e;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .centered { text-align: center; }
  .section-head { text-align: center; margin-bottom: 48px; }
  .section-head h2 { font-size: 2.1rem; }

  .btn {
    display: inline-block;
    padding: 14px 26px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    border: 1.5px solid transparent;
    transition: all 0.15s ease;
  }
  .btn-primary { background: #2a3445; color: #fafaf8; border-color: #2a3445; }
  .btn-primary:hover { background: #1a2233; color: #fafaf8; }
  .btn-ghost { background: transparent; color: #2a3445; border-color: #2a3445; }
  .btn-ghost:hover { background: #2a3445; color: #fafaf8; }

  /* PROFILE HERO */
  .profile-hero {
    background:
      radial-gradient(circle at 15% 25%, rgba(180,160,130,0.20), transparent 45%),
      radial-gradient(circle at 85% 75%, rgba(120,140,130,0.16), transparent 45%),
      linear-gradient(180deg, #f5f1e8 0%, #ede7d8 100%);
    padding: 90px 0 100px;
  }
  .profile-inner {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 56px;
    align-items: center;
  }
  .profile-avatar { text-align: center; }
  .avatar-ring {
    width: 220px; height: 220px;
    border-radius: 50%;
    padding: 8px;
    background: linear-gradient(135deg, #b5946a, #6a4f33);
    margin: 0 auto 18px;
    box-shadow: 0 18px 50px -25px rgba(0,0,0,0.5);
  }
  .avatar-disc {
    width: 100%; height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, #d4c4a8, #8a7a5e);
    box-shadow: inset 0 -10px 24px rgba(0,0,0,0.2);
  }
  .profile-line {
    display: block;
    font-family: Georgia, serif;
    color: #6a5a44;
    font-size: 0.92rem;
    font-style: italic;
  }
  .profile-text h1 {
    font-size: clamp(2.4rem, 4.8vw, 3.8rem);
    font-style: italic;
    margin: 6px 0 14px;
  }
  .lifespan {
    color: #8a7a5e;
    font-size: 1.05rem;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }
  .profile-quote {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 1.2rem;
    color: #3a3a3a;
    padding-left: 18px;
    border-left: 3px solid #b5946a;
    margin-bottom: 32px;
  }
  .profile-quote .mark { font-size: 2rem; color: #b5946a; line-height: 0; vertical-align: -0.4em; margin-right: 4px; }
  .profile-cta { display: flex; gap: 14px; flex-wrap: wrap; }

  /* FACTS */
  .facts-section { padding: 50px 0; }
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .fact {
    padding: 24px 20px;
    text-align: center;
    border-right: 1px solid var(--border);
  }
  .fact:last-child { border-right: none; }
  .fact-label {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: #8a7a5e;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .fact-value { font-family: Georgia, serif; font-size: 1.02rem; font-weight: 700; }
  .fact-sub { color: var(--text-muted); font-size: 0.82rem; margin-top: 2px; }

  /* BIO */
  .bio-para {
    font-size: 1.08rem;
    line-height: 1.8;
    color: #3a3a3a;
    margin-top: 20px;
  }

  /* TREE */
  .section-tree { background: #f1efe9; padding-bottom: 90px; }
  .tree-frame {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 48px 32px 56px;
    position: relative;
    overflow: hidden;
  }
  .tree-controls {
    position: absolute;
    top: 20px; right: 20px;
    display: flex; gap: 6px;
    z-index: 2;
  }
  .tree-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--white);
    color: #2a3445;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .tree-btn:hover { background: #2a3445; color: #fafaf8; border-color: #2a3445; }

  .tree-canvas { display: flex; flex-direction: column; align-items: center; }

  .tree-row { display: flex; justify-content: center; align-items: flex-start; gap: 32px; width: 100%; }
  .tree-row-parents { gap: 220px; }
  .tree-row-self { gap: 40px; justify-content: space-between; align-items: center; }
  .tree-row-children { gap: 28px; }

  .sibling-cluster { display: flex; gap: 16px; }
  .couple {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .couple-link {
    display: flex; align-items: center;
    color: #b5946a;
    font-size: 1.3rem;
  }
  .couple-line {
    width: 24px; height: 2px; background: #b5946a;
    display: inline-block;
  }
  .couple-mark { padding: 0 4px; }

  .tree-node {
    width: 150px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 12px 14px;
    text-align: center;
    box-shadow: 0 6px 20px -12px rgba(0,0,0,0.25);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    position: relative;
  }
  .tree-node:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px -12px rgba(0,0,0,0.3);
  }
  .tree-node-sm { width: 130px; padding: 12px 8px 12px; }
  .tree-node-lg { width: 175px; padding: 20px 14px 18px; }
  .tree-node.is-self { border: 2px solid #b5946a; }

  .node-avatar {
    width: 56px; height: 56px;
    border-radius: 50%;
    margin: 0 auto 10px;
    background: linear-gradient(135deg, #c8b89a, #8a7a5e);
    box-shadow: inset 0 -4px 10px rgba(0,0,0,0.18);
  }
  .tree-node-lg .node-avatar { width: 72px; height: 72px; }
  .tint-sepia .node-avatar { background: linear-gradient(135deg, #b5946a, #6a4f33); }
  .tint-sage  .node-avatar { background: linear-gradient(135deg, #8a9c82, #4a5c50); }
  .tint-rose  .node-avatar { background: linear-gradient(135deg, #b58e8a, #6a4a4a); }

  .node-name {
    font-family: Georgia, serif;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.25;
    color: var(--text);
  }
  .tree-node-sm .node-name { font-size: 0.85rem; }
  .tree-node-lg .node-name { font-size: 1.05rem; }
  .node-dates { color: #8a7a5e; font-size: 0.78rem; letter-spacing: 0.04em; margin-top: 4px; }

  .node-tag {
    display: inline-block;
    margin-top: 8px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #8a7a5e;
    font-weight: 600;
  }

  .tree-connector { width: 100%; height: 64px; display: block; }
  .connector-parents { max-width: 800px; }
  .connector-children { max-width: 800px; }

  /* RECORDS */
  .records { display: flex; flex-direction: column; gap: 12px; margin-top: 28px; }
  .record {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 22px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 6px;
  }
  .record-icon {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: #f1efe9;
    display: grid; place-items: center;
    font-size: 1.2rem;
    flex-shrink: 0;
  }
  .record-body { flex: 1; }
  .record-kind { font-family: Georgia, serif; font-weight: 700; font-size: 1rem; }
  .record-year { color: #8a7a5e; font-weight: 400; }
  .record-source { color: var(--text-muted); font-size: 0.88rem; margin-top: 2px; }
  .record-link {
    color: #2a3445;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .record-link:hover { color: #b5946a; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .profile-inner { grid-template-columns: 1fr; gap: 32px; text-align: center; }
    .profile-quote { border-left: none; padding-left: 0; text-align: center; }
    .profile-cta { justify-content: center; }
    .facts-grid { grid-template-columns: repeat(3, 1fr); }
    .fact:nth-child(3) { border-right: none; }
    .fact:nth-child(-n+3) { border-bottom: 1px solid var(--border); }
    .tree-row-parents { gap: 80px; }
    .tree-row-self { flex-direction: column; gap: 24px; }
    .sibling-cluster { flex-wrap: wrap; justify-content: center; }
    .tree-connector { display: none; }
  }
  @media (max-width: 640px) {
    .facts-grid { grid-template-columns: repeat(2, 1fr); }
    .fact { border-right: none; border-bottom: 1px solid var(--border); }
    .tree-row-children { flex-wrap: wrap; }
  }
</style>
