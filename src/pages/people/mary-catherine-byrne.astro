---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import personData from '../../data/people/mary-catherine-byrne.json';

const { tree, ...person } = personData;
---

<Layout title={`${person.name} — Genealogy Site`} description={`Profile and family tree for ${person.name}, ${person.born.split(',')[1].trim()}–${person.died.split(',')[1].trim()}.`}>
  <Header />

  <main>
    <!-- PROFILE HERO -->
    <section class="profile-hero">
      <div class="container profile-inner">
        <div class="profile-avatar">
          <div class="avatar-ring">
            <div class="avatar-disc"></div>
          </div>
          <span class="profile-line">b. {person.born.split(',')[0]}</span>
          <span class="profile-line">d. {person.died.split(',')[0]}</span>
        </div>
        <div class="profile-text">
          <p class="eyebrow">Member profile</p>
          <h1>{person.name}</h1>
          <p class="lifespan">{person.born.split(',').pop()?.trim()}&nbsp;–&nbsp;{person.died.split(',').pop()?.trim()} · aged {person.age}</p>
          <blockquote class="profile-quote">
            <span class="mark">&ldquo;</span>{person.quote}
          </blockquote>
          <div class="profile-cta">
            <a href="#tree" class="btn btn-primary">View family tree</a>
            <a href="#bio" class="btn btn-ghost">Read biography</a>
          </div>
        </div>
      </div>
    </section>

    <!-- QUICK FACTS -->
    <section class="section facts-section">
      <div class="container">
        <div class="facts-grid">
          {person.facts.map(f => (
            <div class="fact">
              <p class="fact-label">{f.label}</p>
              <p class="fact-value">{f.value}</p>
              <p class="fact-sub">{f.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BIOGRAPHY -->
    <section id="bio" class="section section-alt">
      <div class="container narrow">
        <p class="eyebrow centered">Biography</p>
        <h2 class="centered">A life across two countries</h2>
        {person.bio.map(p => <p class="bio-para">{p}</p>)}
      </div>
    </section>

    <!-- FAMILY TREE -->
    <section id="tree" class="section section-tree">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Family tree</p>
          <h2>{person.name.split(' ')[0]}'s family</h2>
        </div>

        <div class="tree-frame">
          <div class="tree-controls" aria-hidden="true">
            <button class="tree-btn" title="Zoom in">+</button>
            <button class="tree-btn" title="Zoom out">−</button>
            <button class="tree-btn" title="Reset">⟳</button>
          </div>

          <div class="tree-canvas">
            <!-- Row 1: parents -->
            <div class="tree-row tree-row-parents">
              {tree.ancestors.map(p => (
                <div class={`tree-node tint-${p.tint}`}>
                  <div class="node-avatar"></div>
                  <p class="node-name">{p.name}</p>
                  <p class="node-dates">{p.dates}</p>
                </div>
              ))}
            </div>

            <!-- Connector: parents → self -->
            <svg class="tree-connector connector-parents" viewBox="0 0 800 80" preserveAspectRatio="none" aria-hidden="true">
              <path d="M 200 0 L 200 30 L 400 30 L 400 80 M 600 0 L 600 30 L 400 30" stroke="#b5a892" stroke-width="2" fill="none"/>
            </svg>

            <!-- Row 2: self + spouse, with siblings flanking -->
            <div class="tree-row tree-row-self">
              <div class="sibling-cluster">
                {tree.siblings.slice(0, 2).map(s => (
                  <div class={`tree-node tree-node-sm tint-${s.tint}`}>
                    <div class="node-avatar"></div>
                    <p class="node-name">{s.name}</p>
                    <p class="node-dates">{s.dates}</p>
                  </div>
                ))}
              </div>

              <div class="couple">
                <div class={`tree-node tree-node-lg tint-${tree.self.tint} is-self`}>
                  <div class="node-avatar"></div>
                  <p class="node-name">{tree.self.name}</p>
                  <p class="node-dates">{tree.self.dates}</p>
                  <span class="node-tag">This profile</span>
                </div>
                <div class="couple-link" aria-hidden="true">
                  <span class="couple-line"></span>
                  <span class="couple-mark">∞</span>
                </div>
                <div class={`tree-node tree-node-lg tint-${tree.spouse.tint}`}>
                  <div class="node-avatar"></div>
                  <p class="node-name">{tree.spouse.name}</p>
                  <p class="node-dates">{tree.spouse.dates}</p>
                  <span class="node-tag">Spouse</span>
                </div>
              </div>

              <div class="sibling-cluster">
                {tree.siblings.slice(2).map(s => (
                  <div class={`tree-node tree-node-sm tint-${s.tint}`}>
                    <div class="node-avatar"></div>
                    <p class="node-name">{s.name}</p>
                    <p class="node-dates">{s.dates}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Connector: couple → children -->
            <svg class="tree-connector connector-children" viewBox="0 0 800 80" preserveAspectRatio="none" aria-hidden="true">
              <path d="M 400 0 L 400 30 L 120 30 L 120 80 M 400 30 L 320 30 L 320 80 M 400 30 L 520 30 L 520 80 M 400 30 L 720 30 L 720 80" stroke="#b5a892" stroke-width="2" fill="none"/>
            </svg>

            <!-- Row 3: children -->
            <div class="tree-row tree-row-children">
              {tree.children.map(c => (
                <div class={`tree-node tree-node-sm tint-${c.tint}`}>
                  <div class="node-avatar"></div>
                  <p class="node-name">{c.name}</p>
                  <p class="node-dates">{c.dates}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- RECORDS / SOURCES -->
    <section class="section">
      <div class="container narrow">
        <p class="eyebrow">Source records</p>
        <h2>Documents on file</h2>
        <ul class="records">
          {person.records.map(r => (
            <li class="record">
              <div class="record-icon">📄</div>
              <div class="record-body">
                <p class="record-kind">{r.kind} <span class="record-year">· {r.year}</span></p>
                <p class="record-source">{r.source}</p>
              </div>
              <a href={r.href || "#"} class="record-link">View &rarr;</a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

