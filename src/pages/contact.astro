---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import business from '../data/business.json';
import seo from '../data/seo.json';
import contact from '../data/contact.json';
---

<Layout title={seo.contact.title} description={seo.contact.description}>
  <Header />
  <main>
    <section class="hero">
      <div class="container hero-inner">
        <p class="eyebrow">{contact.hero.eyebrow}</p>
        <h1>{contact.hero.heading}</h1>
        <p class="lede">{contact.hero.lede}</p>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container narrow">
        {contact.body.map(para => <p class="bio-para">{para}</p>)}

        {contact.showEmail && (
          <p class="contact-email">
            <strong>Email:</strong>{" "}
            <a href={`mailto:${business.email}`}>{business.email}</a>
          </p>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .contact-email {
    margin-top: 28px;
    font-size: 1.05rem;
  }
</style>
