---
// Page structure lives here; editable content is sourced from src/data/*.json
// so Site Manager's chat and form editors can update it without touching .astro.
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import seo from '../data/seo.json';
import home from '../data/home.json';
import tiles from '../data/tiles.json';
import people from '../data/people.json';
import features from '../data/features.json';
import stories from '../data/stories.json';
import gallery from '../data/gallery.json';

// Gallery strip is a fixed 6-slot grid in the mockup. Fill real photos from
// gallery.json into the first slots; remaining slots stay as decorative
// gradient placeholders until more photos arrive.
const GALLERY_SLOTS = 6;
const FOOTER_SLOTS = 6;
const gallerySlots = Array.from({ length: GALLERY_SLOTS }, (_, i) => gallery[i] ?? null);
const footerSlots = Array.from({ length: FOOTER_SLOTS }, (_, i) => gallery[i] ?? null);
---

<Layout title={seo.index.title} description={seo.index.description}>
  <Header />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <p class="eyebrow">{home.hero.eyebrow}</p>
        <h1>{home.hero.heading}</h1>
        <p class="lede">{home.hero.lede}</p>
        <div class="hero-cta">
          <a href={home.hero.primaryCta.href} class="btn btn-primary">{home.hero.primaryCta.label}</a>
          <a href={home.hero.secondaryCta.href} class="btn btn-ghost">{home.hero.secondaryCta.label}</a>
        </div>
      </div>
    </section>

    <!-- 3 TILE BANNER -->
    <section class="section tiles-section">
      <div class="container">
        <div class="tiles">
          {tiles.map(t => (
            <a href={t.href || '#'} class={`tile tint-${t.tint}`}>
              <span class="tile-label">{t.label}</span>
              <span class="tile-count">{t.count}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- RECENT ADDITIONS -->
    <section id="people" class="section">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">{home.sections.recent.eyebrow}</p>
          <h2>{home.sections.recent.heading}</h2>
        </div>
        <div class="member-row">
          {people.map(p => (
            <a href={p.slug ? `/people/${p.slug}` : '#'} class="member-card-link">
              <article class="member-card">
                <div class="avatar"></div>
                <h3>{p.name}</h3>
                <p class="dates">{p.dates}</p>
                <p class="note">{p.note}</p>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">{home.sections.features.eyebrow}</p>
          <h2>{home.sections.features.heading}</h2>
        </div>
        <div class="feature-grid">
          {features.map((f, i) => (
            <a href={f.href || '#'} class={`feature feature-${i}`}>
              <div class="feature-art"></div>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- PULL QUOTE -->
    <section class="quote-section">
      <div class="container">
        <blockquote>
          <span class="mark">&ldquo;</span>
          {home.sections.quote.text}
          <cite>{home.sections.quote.attribution}</cite>
        </blockquote>
      </div>
    </section>

    <!-- GALLERY STRIP -->
    <section class="section">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">{home.sections.gallery.eyebrow}</p>
          <h2>{home.sections.gallery.heading}</h2>
        </div>
        <div class="gallery-strip">
          {gallerySlots.map((slot, i) => (
            slot
              ? <img src={slot.image} alt={slot.alt || ''} class={`gphoto gphoto-${i}`} loading="lazy" />
              : <div class={`gphoto gphoto-${i}`}></div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAMILY TREE PREVIEW -->
    <section id="tree" class="section section-tree">
      <div class="container tree-grid">
        <div class="tree-art">
          <svg viewBox="0 0 400 280" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g fill="none" stroke="#b5a892" stroke-width="1.5">
              <line x1="200" y1="40" x2="120" y2="120"/>
              <line x1="200" y1="40" x2="280" y2="120"/>
              <line x1="120" y1="120" x2="70" y2="220"/>
              <line x1="120" y1="120" x2="170" y2="220"/>
              <line x1="280" y1="120" x2="230" y2="220"/>
              <line x1="280" y1="120" x2="330" y2="220"/>
            </g>
            <g fill="#fafaf8" stroke="#7a6a52" stroke-width="2">
              <circle cx="200" cy="40" r="22"/>
              <circle cx="120" cy="120" r="20"/>
              <circle cx="280" cy="120" r="20"/>
              <circle cx="70" cy="220" r="18"/>
              <circle cx="170" cy="220" r="18"/>
              <circle cx="230" cy="220" r="18"/>
              <circle cx="330" cy="220" r="18"/>
            </g>
          </svg>
        </div>
        <div class="tree-copy">
          <p class="eyebrow">{home.sections.tree.eyebrow}</p>
          <h2>{home.sections.tree.heading}</h2>
          <p>{home.sections.tree.body}</p>
          <a href={home.sections.tree.ctaHref} class="btn btn-primary">{home.sections.tree.ctaLabel}</a>
        </div>
      </div>
    </section>

    <!-- STORIES TEASER -->
    <section class="section">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">{home.sections.stories.eyebrow}</p>
          <h2>{home.sections.stories.heading}</h2>
        </div>
        <div class="story-row">
          {stories.map((s, i) => (
            <a href={s.href || '#'} class="story-link">
              <article class={`story story-${i}`}>
                <div class="story-art"></div>
                <p class="meta">{s.date} · {s.read}</p>
                <h3>{s.title}</h3>
              </article>
            </a>
          ))}
        </div>
        <div class="centered">
          <a href={home.sections.stories.viewAllHref} class="btn btn-ghost">{home.sections.stories.viewAllLabel}</a>
        </div>
      </div>
    </section>

    <!-- FOOTER PHOTO GRID -->
    <section class="footer-strip">
      <div class="footer-grid">
        {footerSlots.map((slot, i) => (
          slot
            ? <img src={slot.image} alt={slot.alt || ''} class={`fphoto fphoto-${i}`} loading="lazy" />
            : <div class={`fphoto fphoto-${i}`}></div>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
